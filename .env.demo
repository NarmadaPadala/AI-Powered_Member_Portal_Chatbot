# Copy this file to `.env` and fill in your own credentials.
#   cp .env.demo .env

# OpenAI - used for embeddings (text-embedding-3-small) and chat (gpt-4.1-mini)
OPENAI_API_KEY=your-openai-api-key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4.1-mini

# Pinecone - vector store for the RAG index
PINECONE_API_KEY=your-pinecone-api-key

# Name of your Pinecone index (512-dim vectors, cosine similarity)
PINECONE_INDEX_NAME=healthcare-support-rag
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_NAMESPACE=demo-healthcare-support
PINECONE_DIMENSION=512
